<Window x:Class="FrontEnd.Dialogs.IntakeBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrontEnd.Dialogs"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Saisie"
        Height="200" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0E0F0E"
        Closed="Window_Closed">

    <Window.Resources>
        <ResourceDictionary Source="/Ressources/Styles.xaml"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,20,20,0" VerticalAlignment="Top">
            <TextBlock x:Name="txtBlock_message"
                       Text="{Binding Message}"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="13"
                       Foreground="{StaticResource LLM.TextSecondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>
            <TextBox x:Name="txt_content"
                     Style="{StaticResource LLM.TextBox}"
                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     Height="36"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource LLM.Surface}"
                BorderBrush="{StaticResource LLM.Border}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Click="Btn_annuler_clk"
                        Content="Annuler"
                        Width="90" Height="32"
                        Style="{StaticResource LLM.Button.Ghost}"/>
                <Button Click="Btn_confirmer_clk"
                        Content="Confirmer"
                        Width="116" Height="33"
                        Margin="8,0,0,0"
                        Style="{StaticResource LLM.Button.Primary}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
