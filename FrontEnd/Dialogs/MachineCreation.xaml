<Window x:Class="FrontEnd.Dialogs.MachineCreation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrontEnd.Dialogs"
        mc:Ignorable="d"
        Title="L.L.M création de machine"
        Foreground="{StaticResource LLM.TextPrimary}"
        Background="{StaticResource LLM.Base}"
        Height="350" Width="580" Icon="/Assets/Images/app_icon.ico">
    <Window.Resources>
        <ResourceDictionary Source="/Ressources/Styles.xaml"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0"
            Background="{StaticResource LLM.Surface}"
            BorderBrush="{StaticResource LLM.Border}"
            BorderThickness="0,0,0,1"
            Padding="20,0">
            <TextBlock Text="CRÉATION DE MACHINE"
                   FontFamily="Cascadia Code, Consolas"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{StaticResource LLM.TextPrimary}"
                   VerticalAlignment="Center"/>
        </Border>


        <Grid Grid.Row="1" Margin="20,16" ScrollViewer.CanContentScroll="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <Grid Grid.Row="0" Margin="0,0,0,10" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="NOM D'AFFICHAGE"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource LLM.TextPrimary}"
                           Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MachineName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LLM.TextBox}" Height="46" CharacterCasing="Upper"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="ADRESSE IP"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource LLM.TextPrimary}"
                           Margin="0,0,0,4"/>
                    <TextBox Text="{Binding MachineIpAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LLM.TextBox}" Height="46" CharacterCasing="Upper"/>
                </StackPanel>
            </Grid>


            <TextBlock Grid.Row="2"
                   Text="DESCRIPTION"
                   FontFamily="Cascadia Code, Consolas"
                   FontSize="9" FontWeight="Bold"
                   Foreground="{StaticResource LLM.TextPrimary}"
                   Margin="0,0,0,6"/>


            <Border Grid.Row="3"
                Background="{StaticResource LLM.Surface2}"
                BorderBrush="{StaticResource LLM.Border}"
                BorderThickness="1"
                CornerRadius="3"
                Padding="8" Margin="0,0,0,-2">
                <TextBox Text="{Binding MachineDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource LLM.TextBox}"/>   
            </Border>
        </Grid>

        <Border Grid.Row="2"
            Background="{StaticResource LLM.Surface}"
            BorderBrush="{StaticResource LLM.Border}"
            BorderThickness="0,1,0,0"
            Padding="20,0">
            <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                <Button Content="Annuler"
                    Width="102" Height="32"
                    Click="Btn_cancel_clk"
                    Style="{StaticResource LLM.Button.Ghost}"/>
                <Button Content="Créer"
                    Width="102" Height="32"
                    Margin="8,0,0,0" 
                    Click="Commit_btn_clk"
                    Style="{StaticResource LLM.Button.Primary}"
                    IsEnabled="{Binding CanCommit}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
