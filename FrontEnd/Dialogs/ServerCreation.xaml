<Window x:Class="FrontEnd.Dialogs.ServerCreation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrontEnd.Dialogs"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="MainWindow" Height="280" Width="650"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#FFE8F6CE">
    <Canvas>
        <Label Canvas.Left="235" Canvas.Top="10" HorizontalAlignment="Left" Height="33" VerticalAlignment="Center" Width="180">
            <TextBlock Text="Création de serveur" VerticalAlignment="Center" FontSize="18" TextAlignment="Center" Width="180" Height="33"/>
        </Label>
        <StackPanel Canvas.Top="39" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Width="630" Canvas.Left="10">
            <Grid Margin="8" VerticalAlignment="Center" Width="153">
                <ui:RichTextBox HorizontalAlignment="Center" VerticalAlignment="Center" Width="174"/>
                <Label Content="nom d'affichage" Margin="10,10,36,10"/>
            </Grid>
            <Grid Margin="0,0,5,0" VerticalAlignment="Center" Width="180">
                <ui:RichTextBox HorizontalAlignment="Center" VerticalAlignment="Center" Width="174"/>
                <Label HorizontalContentAlignment="Right" Content="adresse ip" FontSize="14" Margin="75,10,10,10"/>
            </Grid>
        </StackPanel>
        <Label Canvas.Left="21" Canvas.Top="103" HorizontalAlignment="Center" VerticalAlignment="Top" Width="69" Height="24">
            <TextBlock FontSize="18" Text="Services" Width="69"/>
        </Label>
        <ItemsControl x:Name="Lst_service" Canvas.Left="21" Canvas.Top="132" HorizontalAlignment="Left" Background="White" VerticalAlignment="Center" Width="334" Height="73">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="service" Margin="2" Background="#B3CCCCCC"/>
            <ui:Button Content="+" Margin="2" Background="#B3CCCCCC">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Items.Count, ElementName=Lst_service}" Value="9">
                                <Setter Property="Visibility" Value="Hidden"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
        </ItemsControl>

    </Canvas>
</Window>
