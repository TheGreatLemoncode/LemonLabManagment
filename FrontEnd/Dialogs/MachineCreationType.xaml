<Window x:Class="FrontEnd.Dialogs.MachineCreationType"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrontEnd.Dialogs"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="MainWindow" Height="270" Width="370"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#FFE8F6CE">
    <Canvas>
        <Label HorizontalContentAlignment="Center" Canvas.Left="64" Canvas.Top="10" Height="50" Width="242" HorizontalAlignment="Left" VerticalAlignment="Center">
            <ui:TextBlock TextAlignment="Center" FontSize="32" Text="Type de machine"/>
        </Label>
        <ListBox x:Name="Lst_options" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" Canvas.Top="65" Canvas.Left="24" HorizontalAlignment="Left" VerticalAlignment="Top" Width="322" Height="102" SelectedIndex="-1">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ui:TextBlock Background="LimeGreen" Height="24" Width="80" TextAlignment="Center" Text="Serveur"/>
            <ui:TextBlock Background="LimeGreen" Height="24" Width="80" TextAlignment="Center" Text="Routeur"/>
            <ui:TextBlock Background="LimeGreen" Height="24" Width="80" TextAlignment="Center" Text="Machine"/>
            <ui:TextBlock Background="LimeGreen" Height="24" Width="80" TextAlignment="Center" Text="Imprimante" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <ui:TextBlock Background="LimeGreen" Text="Ordinateur" TextAlignment="Center" Width="80" Height="24"/>
        </ListBox>
        <DockPanel Canvas.Left="35" Canvas.Top="186" HorizontalAlignment="Left" Width="300" VerticalAlignment="Top">
            <ui:Button DockPanel.Dock="Right" Content="Confirmer" Height="30" Width="90">
                <ui:Button.Style>
                    <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type ui:Button}">
                        <Setter Property="IsEnabled"  Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedItem, ElementName=Lst_options}" Value="{x:Null}">
                                <Setter Property="IsEnabled"  Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
            <ui:Button Content="Annuler" DockPanel.Dock="Right" Height="30" Width="90"/>
        </DockPanel>
    </Canvas>
</Window>
