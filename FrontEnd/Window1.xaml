<Window x:Class="FrontEnd.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FrontEnd"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">

    <Canvas>
        <ui:Button Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" BorderBrush="#FFC68A00" Canvas.Left="325" Canvas.Top="142" HorizontalAlignment="Center" Height="131" VerticalAlignment="Top">
            <StackPanel Width="150" Height="108" >
                <DockPanel Height="43" Margin="0,5,0,5" Width="173">
                    <TextBlock DockPanel.Dock="Left" Text="Routeur" Width="78" TextAlignment="Center" Height="27" Foreground="#FF1A1A1A" FontSize="16" FontFamily="Cascadia Code"/>
                    <Ellipse DockPanel.Dock="Right" Width="37" Height="36" Fill="Red"/>
                </DockPanel>
                <DockPanel Height="24"  Background="#FF825252" Width="120">
                    <TextBlock DockPanel.Dock="Left" FontFamily="Cascadia Code" TextAlignment="Center" Text="192.168.0.111" Width="117" Height="24" Foreground="#FF1A1A1A"/>
                </DockPanel> 
                <DockPanel Height="29" Margin="0,6,0,0" >
                    <TextBlock DockPanel.Dock="Left" TextAlignment="Center" Text="Im an alien" Width="85" Height="24" Foreground="#FF1A1A1A"/>
                </DockPanel>
            </StackPanel>
        </ui:Button>

    </Canvas>
</Window>
