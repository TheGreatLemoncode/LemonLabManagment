<UserControl x:Class="FrontEnd.Controls.Connexion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Controls"
             mc:Ignorable="d" 
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DesignHeight="450" d:DesignWidth="800">
    <Canvas>
        <StackPanel Background="#FFC9DAEC" Canvas.Left="175" Canvas.Top="52" Height="290" Width="450" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Label HorizontalAlignment="Center"  Height="37" Width="232" Margin="0,13,0,0">
                <ui:TextBlock FontSize="20" FontFamily="Cascadia Code" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Top" Width="232" Height="40" Text="Connexion au compte" Foreground="#FF0F172A"/>
            </Label>

            <StackPanel Margin="0,12,0,0">
                <Label FontSize="18" Content="Mail" Width="357" Foreground="#FF0F172A"/>
                <ui:TextBox Width="357"/>
            </StackPanel>
            <StackPanel Margin="0,18,0,0">
                <Label FontSize="18" Content="Mot de passe" Width="357" Foreground="#FF0F172A"/>
                <ui:TextBox Width="357"/>
            </StackPanel>
            <ui:Button Margin="0,19,0,0" HorizontalAlignment="Center" Width="106" Height="36" Background="#FF3B82F6">
                <ui:TextBlock Text="Connexion" Foreground="#FF0F172A"/>
            </ui:Button>
        </StackPanel>
        <Rectangle Fill="#FF4B4C4C" Canvas.Left="191" Canvas.Top="67" Height="290" Width="450" Panel.ZIndex="-1" Opacity="0.63" HorizontalAlignment="Left" VerticalAlignment="Center"/>
    </Canvas>
</UserControl>
