<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Controls.MainMenuControls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="FrontEnd.Controls.MainMenuControls.Compte"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <ui:Image Height="100" Width="154" Margin="0,20,0,0" Source="/Assets/Images/placeholder-image.png"/>
            <ui:TextBlock Text="{Binding Name}" FontSize="24" Margin="55,0,0,0"/>
            <StackPanel HorizontalAlignment="Center">
                <ui:Button Click="join_btn_clk" Content="Rejoindre une organisation" Height="67" Width="193" Margin="0,10,0,0"/>
                <ui:Button Click="create_btn_clk" Content="Créer une organisation" Height="67" Width="193" Margin="0,10,0,0"/>
                <ui:Button Content="Déconnexion" Height="67" Width="193" Margin="0,10,0,0"/>
            </StackPanel>
        </StackPanel>
        <ui:TextBlock Text="{Binding Organisation.code, StringFormat=organisation : {0}}" Margin="585,10,72,396"/>
    </Grid>
</UserControl>
