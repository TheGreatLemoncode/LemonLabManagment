<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Controls.MainMenuControls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="FrontEnd.Controls.MainMenuControls.Compte"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Canvas>
        <StackPanel HorizontalAlignment="Center" Canvas.Left="150" VerticalAlignment="Center">
            <ui:Image Height="100" Width="154" Margin="0,20,0,0" Source="/Assets/Images/placeholder-image.png"/>
            <ui:TextBlock Text="{Binding Name}" FontSize="24" HorizontalAlignment="Center"/>
            <StackPanel HorizontalAlignment="Center">
                <ui:Button Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" FontFamily="Cascadia Code" Click="join_btn_clk" Height="56" Width="210" Margin="0,10,0,0">
                    <ui:TextBlock Text="Rejoindre Organisation" TextWrapping="Wrap" Height="18" Width="184"/>
                </ui:Button>
                <ui:Button Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" FontFamily="Cascadia Code" Click="create_btn_clk" Content="Créer une organisation" Height="56" Width="210" Margin="0,10,0,0"/>
                <ui:Button Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" FontFamily="Cascadia Code" Content="Déconnexion" Height="56" Width="210" Margin="0,10,0,0"/>
            </StackPanel>
        </StackPanel>
        <DockPanel Canvas.Left="400" Canvas.Top="37" Height="33" Width="163" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#FFF3FBE6">
            <ui:TextBlock FontFamily="Cascadia Code" Text="100000" HorizontalAlignment="Left" VerticalAlignment="Center" Width="auto"/>
            <ui:Button Content="O" DockPanel.Dock="Right" HorizontalAlignment="Right" ToolTip="Copier le code"/>
        </DockPanel>
        
    </Canvas>
</UserControl>
