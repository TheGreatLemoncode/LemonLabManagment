<UserControl x:Class="FrontEnd.Controls.CreationCompte"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="CheckField" TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding isCorrect}" Value="False">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FFF03636" Opacity="0.8" BlurRadius="10" ShadowDepth="10"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding isCorrect}" Value="True">
                    <Setter Property="Effect" Value="{x:Null}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Storyboard x:Key="BackGroundRotation">
            <DoubleAnimation Storyboard.TargetName="SliceRotation" Storyboard.TargetProperty="Angle" From="0" To="360"
                             Duration="0:0:25" RepeatBehavior="Forever"/>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{DynamicResource BackGroundRotation}"/>
        </EventTrigger>
    </UserControl.Triggers>
    
    <Canvas>
        <StackPanel Panel.ZIndex="0" x:Name="StackField" Background="#FBFDF8" Canvas.Left="177" Canvas.Top="32" Height="340" Width="448" HorizontalAlignment="Left" VerticalAlignment="Top" >
            <Label HorizontalAlignment="Center"  Height="37" Width="262" Margin="8,13,0,0" HorizontalContentAlignment="Center">
                <ui:TextBlock FontSize="22" FontFamily="Cascadia Code" TextWrapping="Wrap" HorizontalAlignment="Left" VerticalAlignment="Top" Width="252" Height="37" Text="Inscription À L.L.M" Foreground="#2B2B2B"/>
            </Label>

            <StackPanel Margin="0,12,0,0">
                <Label FontFamily="Cascadia Code" FontSize="18" Content="Courriel" Width="357" Foreground="#66705F" Opacity="0.9"/>
                <ui:TextBox FontSize="18" Style="{DynamicResource CheckField}" FontFamily="Cascadia Code" x:Name="txt_mail" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" Width="358" LostKeyboardFocus="TextBox_LostKeyboardFocus" Height="40" BorderBrush="#FFE6EBD9" Foreground="#FF2E2E2E" SelectionBrush="#FFF4C430"/>
            </StackPanel>
            <StackPanel Margin="0,12,0,0">
                <Label FontFamily="Cascadia Code" FontSize="18" Content="Nom d'affichage" Width="357" Foreground="#66705F" Opacity="0.9"/>
                <ui:TextBox FontSize="18" Style="{DynamicResource CheckField}" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}" FontFamily="Cascadia Code" x:Name="txt_name" Width="358" Height="40" LostKeyboardFocus="Name_TextBox_LostKeyboardFocus" BorderBrush="#FFE6EBD9" Foreground="#FF2E2E2E" SelectionBrush="#FFF4C430"/>
            </StackPanel>
            <StackPanel Margin="0,18,0,0">
                <Label FontFamily="Cascadia Code" FontSize="18" Content="Mot de passe" Width="357" Foreground="#66705F" Opacity="0.9"/>
                <ui:PasswordBox x:Name="pwd_user" FontSize="18" FontFamily="Cascadia Code" Width="358" Height="40" BorderBrush="#FFE6EBD9" Foreground="#FF2E2E2E" SelectionBrush="#FFF4C430"/>
            </StackPanel>
            <DockPanel Margin="0,10,0,0" Height="50" Width="289" >
                <ui:Button Click="creation_btn_clk" DockPanel.Dock="Right" HorizontalAlignment="Right" Width="113" Height="33" Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304">
                    <ui:TextBlock FontFamily="Cascadia Code" Text="Inscription" Foreground="#2B2B2B" Width="95" Height="18"/>
                </ui:Button>
                <ui:Button Click="connexion_btn_clk" DockPanel.Dock="Left" Width="113" Height="33" Background=" #2E2E2E" MouseOverBackground="#FF5D5D5D" PressedBackground="#FFC5C4C4" HorizontalAlignment="Left">
                    <ui:TextBlock FontFamily="Cascadia Code" Text="Connexion" Foreground="#F4C430"/>
                </ui:Button>
            </DockPanel>

        </StackPanel>
        <Rectangle Fill="#FF767777" Canvas.Left="188" Canvas.Top="44" Height="340" Width="450" Panel.ZIndex="-1" Opacity="0.6" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Rectangle.Effect>
                <BlurEffect/>
            </Rectangle.Effect>
        </Rectangle>
        <ui:ImageIcon Panel.ZIndex="1" Source="/Assets/Images/LemonNoBg.png" Height="53" Canvas.Left="564" Width="61" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Top="32"/>
        <Canvas x:Name="BackGroundAnimations" Panel.ZIndex="-2" Width="800" Height="450" Opacity="0.8">
            <Canvas  x:Name="Rotate" Width="700" Height="700" Canvas.Left="50" VerticalAlignment="Top" Canvas.Top="-125" RenderTransformOrigin="0.5,0.5">
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="SliceRotation"/>
                </Canvas.RenderTransform>
                <Ellipse Panel.ZIndex="0" Fill="#18F4C430" Width="700" Height="700" HorizontalAlignment="Center"/>
                <Line X1="350" Y1="0" X2="350" Y2="700"
                    Stroke="#7FD0B768"
                    StrokeThickness="2"/>

                <Line X1="350" Y1="0" X2="350" Y2="700" Stroke="#7FD0B768" StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="45"
                             CenterX="350"
                             CenterY="350"/>
                    </Line.RenderTransform>
                </Line>

                <Line X1="350" Y1="0" X2="350" Y2="700"
                    Stroke="#7FD0B768"
                    StrokeThickness="2">  
                    <Line.RenderTransform>
                        <RotateTransform Angle="90"
                             CenterX="350"
                             CenterY="350"/>
                    </Line.RenderTransform>
                </Line>

                <Line X1="350" Y1="0" X2="350" Y2="700"
                  Stroke="#7FD0B768"
                  StrokeThickness="2">
                    <Line.RenderTransform>
                        <RotateTransform Angle="135"
                             CenterX="350"
                             CenterY="350"/>
                    </Line.RenderTransform>
                </Line>

            </Canvas>
        </Canvas>
    </Canvas>
</UserControl>
