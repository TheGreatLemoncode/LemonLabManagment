<UserControl x:Class="FrontEnd.Controls.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800"
             Background="#FFB2ABAB">
    <Grid>
        <StackPanel Background="#FFB2ABAB" Margin="10,10,626,10">
            <Button Style="{StaticResource BaseButton}" Click="account_btn_clk" Content="Compte" Height="50" Margin="0,85,0,0" Width="140"/>
            <Button Style="{StaticResource BaseButton}" Content="Ajout machine" Height="50" Margin="0,5,0,0" Width="140"/>
            <Button Style="{StaticResource BaseButton}" Content="Toutes les machines" Height="50" Margin="0,5,0,0" Width="140"/>
            <Button Style="{StaticResource BaseButton}" Content="Plan de circuit" Height="50" Margin="0,5,0,0" Width="140"/>

        </StackPanel>
        <ContentControl x:Name="MainMenuDisplay" Margin="189,10,0,10"/>
    </Grid>
</UserControl>
