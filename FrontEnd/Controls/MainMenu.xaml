<UserControl x:Class="FrontEnd.Controls.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:FrontEnd.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Ressources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource LLM.Surface}">
            <DockPanel>

                <Border DockPanel.Dock="Top"
                        Height="52"
                        BorderBrush="{StaticResource LLM.Border}"
                        BorderThickness="0,0,0,1"
                        Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{StaticResource LLM.Accent}"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="L·L·M"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource LLM.TextPrimary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top"
                           Text="NAVIGATION"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource LLM.TextMuted}"
                           Margin="16,16,0,4"/>

                <StackPanel DockPanel.Dock="Top">
                    <Button Style="{StaticResource LLM.NavButton}"
                            Click="acceuil_btn_clk"
                            Content="⌂ Accueil"/>
                    <Button Style="{StaticResource LLM.NavButton}"
                            Click="account_btn_clk"
                            Content="◉ Compte"/>
                    <Button Style="{StaticResource LLM.NavButton}"
                            Click="add_machine_clk"
                            Content="＋ Ajouter machine"/>
                    <Button Style="{StaticResource LLM.NavButton}"
                            Click="All_display_btn_clk"
                            Content="▤ Toutes les machines"/>
                    <Button Style="{StaticResource LLM.NavButton}"
                            Click="canvas_mode_clk"
                            Content="⬡ Plan de circuit"/>
                    <Button Content="À propos" Style="{StaticResource LLM.Button.Primary}" Click="Button_Click"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0 — LLM"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="9"
                           Foreground="{StaticResource LLM.TextMuted}"
                           Margin="16,0,0,12"/>

            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource LLM.Border}"/>

        <Border Grid.Column="2" Background="{StaticResource LLM.Base}">
            <ContentControl x:Name="MainMenuDisplay"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Border>

    </Grid>
</UserControl>
