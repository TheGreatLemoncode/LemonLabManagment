<UserControl x:Class="FrontEnd.Controls.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <Canvas>
        <StackPanel HorizontalAlignment="Left" Canvas.Left="10" Canvas.Top="10" VerticalAlignment="Center" Height="384" Width="173">
            <ui:Button FontFamily="Cascadia Code" Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" Click="acceuil_btn_clk" Content="Acceuil" Height="50" Margin="10,65,0,0" Width="153"/>
            <ui:Button FontFamily="Cascadia Code" Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" Click="account_btn_clk" Content="Compte" Height="50" Margin="10,5,0,0" Width="153"/>
            <ui:Button Click="add_machine_clk" FontFamily="Cascadia Code" Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" Content="Ajout machine" Height="50" Margin="10,5,0,0" Width="153" />
            <ui:Button Click="All_display_btn_clk" FontFamily="Cascadia Code" Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304"  Height="50" Margin="10,5,0,0" Width="153">
                <ui:TextBlock Text="Toutes les machines" TextAlignment="Center" TextWrapping="Wrap" FontFamily="Cascadia Code" FontSize="14" Height="40" Width="130"/>
            </ui:Button>
            <ui:Button FontFamily="Cascadia Code" Background="#F4C430" MouseOverBackground="#FFE6B800" PressedBackground="#FFB79304" Content="Plan de circuit" Height="50" Margin="10,5,0,0" Width="153"/>
        </StackPanel>
        <ContentControl x:Name="MainMenuDisplay" Width="601" HorizontalAlignment="Left" Height="380" VerticalAlignment="Center" Canvas.Left="188" Canvas.Top="10"/>
    </Canvas>
</UserControl>
