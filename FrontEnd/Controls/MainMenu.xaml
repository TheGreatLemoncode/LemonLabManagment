        </StackPanel>

        <StackPanel Margin="179,10,10,10">
            <Expander Height="68" Header="ROUTER" Width="552" FontSize="24">
                <ListBox HorizontalContentAlignment="Center" Margin="0,0,0,-16">
                    <Button Height="40" Width="400" Content="116"/>
                    <Button Height="40" Width="400" Content="16"/>
                    <Button Height="40" Width="400" Content="16"/>
