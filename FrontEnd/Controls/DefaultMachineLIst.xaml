<UserControl x:Class="FrontEnd.Controls.DefaultMachineLIst"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:model="clr-namespace:BackEnd.Models;assembly=BackEnd"
             xmlns:viewmodel="clr-namespace:FrontEnd.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="380" d:DesignWidth="611">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type viewmodel:MachineViewModel}" x:Key="LayoutA">
            <Button Command="{Binding Command}" Margin="2" Height="92" Background="{x:Null}" BorderBrush="{x:Null}" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" Width="161" Padding="0,0,0,0">
                <StackPanel Width="Auto" Background="White">
                    <ui:TextBlock Text="{Binding Name}"/>
                    <ui:TextBlock Text="{Binding Locataire}"/>
                    <ui:TextBlock Text="{Binding Status}"/>
                </StackPanel>
            </Button>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodel:MachineViewModel}" x:Key="LayoutB">
            <Button Command="{Binding Command}" Width="545" Background="Blue" BorderBrush="{x:Null}" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <DockPanel MaxHeight="150">
                    <ui:TextBlock MinWidth="150" Text="{Binding Name}" DockPanel.Dock="Left" TextAlignment="Center"/>
                    <ui:TextBlock MinWidth="150" Text="{Binding Status}" DockPanel.Dock="Right" TextAlignment="Center"/>
                    <ui:TextBlock Text="{Binding Marque, FallbackValue=hellol}" TextWrapping="Wrap"  MaxWidth="150" TextAlignment="Center"/>
                </DockPanel>
            </Button>

        </DataTemplate>
    </UserControl.Resources>
    <Canvas>
        <StackPanel Panel.ZIndex="0" Canvas.Left="14" Canvas.Top="10" HorizontalAlignment="Left" Height="360" VerticalAlignment="Center" Width="587">
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" Height="55" Width="552" Background="#FFEC6060">
                <ui:TextBox x:Name="SearchBarContent" Width="500" FontSize="20" Background="White" Height="50"/>
                <ui:Button Click="Search_btn_clk" Content="Src" Height="50" Width="49" Background="White"/>
            </StackPanel>
            <ui:TextBlock TextAlignment="Center" Panel.ZIndex="0" FontFamily="Cascadia Code" FontSize="32" Text="{Binding PageName, FallbackValue=Acceuil}" Width="330" Margin="0,3,0,0" Height="43"/>
            <ItemsControl x:Name="MachineControls" Width="545" Height="205" Margin="0,7,0,0">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="{x:Type ItemsControl}">
                        <ScrollViewer Margin="0,15,0,0" CanContentScroll="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>

                <ItemsControl.Style>
                    <Style TargetType="{x:Type ItemsControl}">
                        <Setter Property="ItemTemplate" Value="{StaticResource LayoutA}"/>
                        <Setter Property="ItemsPanel">
                            <Setter.Value>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="ItemsSource" Value="{Binding UsedItems}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentLayout}" Value="Default">
                                <Setter Property="ItemTemplate" Value="{StaticResource LayoutA}"/>
                                <Setter Property="ItemsSource" Value="{Binding UsedItems}"/>
                                <Setter Property="ItemsPanel">
                                    <Setter.Value>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentLayout}" Value="All">
                                <Setter Property="ItemTemplate" Value="{StaticResource LayoutB}"/>
                                <Setter Property="ItemsSource" Value="{Binding AllItems}"/>
                                <Setter Property="ItemsPanel">
                                    <Setter.Value>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
            </ItemsControl>
        </StackPanel>
        <ui:Button Content="FLR" Panel.ZIndex="1" Canvas.Left="530" Canvas.Top="81" Height="30" Width="50"/>
    </Canvas>
</UserControl>
