<UserControl x:Class="FrontEnd.Vues.Connexion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FrontEnd.Vues"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <StackPanel Height="360" Margin="118,76,139,14">
            <Label Content="CONNEXION" HorizontalAlignment="Center" FontSize="48"/>
            <TextBox x:Name="txt_mail" Background="#FFC6C2C2" Width="470" Margin="0,10,0,0" FontSize="36" TextChanged="txt_mail_TextChanged"/>
            <PasswordBox x:Name="pwd_password" Background="#FFC6C2C2" Width="470" Margin="0,10,0,0" FontSize="36" PasswordChanged="pwd_password_PasswordChanged"/>
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal" Width="562">
                <Button x:Name="btn_reset" Content="Reset" Height="80" Width="127" Margin="45,0,0,0" Click="reset_btn_clk" FontSize="16"/>
                <Button x:Name="btn_connexion" Content="Connexion" Height="80" Width="131" Margin="45,0,0,0" FontSize="16"/>
                <Button x:Name="btn_creation" Content="Creation compte" Height="80" Width="125" Margin="40,0,0,0" FontSize="16" Click="btn_creation_clk"/>
            </StackPanel>
        </StackPanel>
        <TextBlock x:Name="txtblock_mail" HorizontalAlignment="Left" Margin="540,164,0,0" TextWrapping="Wrap" Text="Mail" VerticalAlignment="Top" FontSize="36"/>
        <TextBlock x:Name="txtblock_pwd" HorizontalAlignment="Left" Margin="459,217,0,0" TextWrapping="Wrap" Text="Password" VerticalAlignment="Top" FontSize="36"/>
    </Grid>
</UserControl>
