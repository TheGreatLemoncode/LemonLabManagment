<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="LLM.Base" Color="#0E0F0E"/>
    <SolidColorBrush x:Key="LLM.Surface" Color="#161817"/>
    <SolidColorBrush x:Key="LLM.Surface2" Color="#1E201E"/>
    <SolidColorBrush x:Key="LLM.Surface3" Color="#252725"/>
    <SolidColorBrush x:Key="LLM.Border" Color="#2E322E"/>
    <SolidColorBrush x:Key="LLM.BorderLight" Color="#3A3F3A"/>
    <SolidColorBrush x:Key="LLM.Accent" Color="#BFFF00"/>
    <SolidColorBrush x:Key="LLM.AccentDim" Color="#7CAA00"/>
    <SolidColorBrush x:Key="LLM.AccentGlow" Color="#30BFFF00"/>
    <SolidColorBrush x:Key="LLM.TextPrimary" Color="#E8EDE8"/>
    <SolidColorBrush x:Key="LLM.TextSecondary" Color="#7A8A7A"/>
    <SolidColorBrush x:Key="LLM.TextMuted" Color="#445044"/>
    <SolidColorBrush x:Key="LLM.StatusOk"  Color="#4ADE80"/>
    <SolidColorBrush x:Key="LLM.StatusWarn"  Color="#FACC15"/>
    <SolidColorBrush x:Key="LLM.StatusErr"  Color="#F87171"/>
    <SolidColorBrush x:Key="LLM.Transparent" Color="#00000000"/>

    <Style x:Key="LLM.NavButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LLM.Transparent}"/>
        <Setter Property="Foreground" Value="{StaticResource LLM.TextSecondary}"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"  Value="16,0,16,0"/>
        <Setter Property="FontFamily"  Value="Cascadia Code, Consolas, Courier New"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor"  Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{StaticResource LLM.Transparent}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource LLM.Surface3}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LLM.AccentDim}"/>
                            <Setter Property="Foreground" Value="{StaticResource LLM.TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LLM.Accent}"/>
                            <Setter Property="Foreground" Value="{StaticResource LLM.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource LLM.TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LLM.NavButton.Active" TargetType="Button" BasedOn="{StaticResource LLM.NavButton}">
        <Setter Property="Foreground" Value="{StaticResource LLM.Accent}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{StaticResource LLM.Surface2}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="{StaticResource LLM.Accent}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LLM.Button.Primary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LLM.Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource LLM.Base}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="20,0"/>
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="2"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#D4FF1A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource LLM.AccentDim}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource LLM.Surface3}"/>
                            <Setter Property="Foreground" Value="{StaticResource LLM.TextMuted}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LLM.Button.Ghost" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LLM.Transparent}"/>
        <Setter Property="Foreground" Value="{StaticResource LLM.TextSecondary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LLM.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="20,0"/>
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="2"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource LLM.Surface3}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LLM.BorderLight}"/>
                            <Setter Property="Foreground" Value="{StaticResource LLM.TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LLM.Accent}"/>
                            <Setter Property="Foreground" Value="{StaticResource LLM.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LLM.TextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource LLM.Surface2}"/>
        <Setter Property="Foreground" Value="{StaticResource LLM.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LLM.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="{StaticResource LLM.Accent}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource LLM.Accent}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" CornerRadius="2"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LLM.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LLM.MachineCard" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LLM.Surface2}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LLM.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Width" Value="160"/>
        <Setter Property="Height" Value="96"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="3"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="{StaticResource LLM.Surface3}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LLM.AccentDim}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LLM.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="LLM.ListRow" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LLM.Transparent}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LLM.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Height" Value="52"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource LLM.Surface2}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="ErrorTextBox" TargetType="TextBox">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#F87171" Opacity="0.9" BlurRadius="8" ShadowDepth="0"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BoxShadow" TargetType="Border">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="16" ShadowDepth="4"/>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
